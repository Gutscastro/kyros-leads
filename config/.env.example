# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA versione o arquivo .env no Git

# Supabase - Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_KEY=sua_publishable_key_aqui

# Serper API (Google Search) - Obtenha em: https://serper.dev/api-key
SERPER_API_KEY=sua_serper_api_key_aqui
